# Copy this file to an ignored local path, replace every /absolute/path value,
# then source it before starting the coordinator. This file contains no secret.

export OMNICODING_ROOT=/absolute/path/to/OmniCoding
export RL_TRAIN_JSONL=/absolute/path/to/rl_train.jsonl
export DATASET_ROOT=/absolute/path/to/benchmark-media
export OMNICODING_RUNTIME_ROOT=/absolute/path/to/omnicoding-runtime
export SAVE_DIR=/absolute/path/to/rl-checkpoints/code-x-27b
export ROLLOUT_SBATCH_SCRIPT="${OMNICODING_ROOT}/infra/slurm/rl_worker.sbatch"

# Required bearer secret. Create this file on storage shared with the trainer,
# for example with `umask 077; openssl rand -hex 32 > /private/path/token`.
# The coordinator and trainer read the file at runtime; its value is never put
# in Ray command arguments or job metadata.
export ROLLOUT_COORDINATOR_TOKEN_FILE=/absolute/private/path/to/coordinator-token

# Exact origins ignore URL paths but include scheme and port. The model value
# is the LiteLLM routing ID sent by the Relax rollout client.
export ROLLOUT_ALLOWED_SGLANG_ORIGINS=http://127.0.0.1:8080
export ROLLOUT_ALLOWED_MODELS=openai/shuaishuaicdp/Code-X-SFT-27B

export ROLLOUT_MAX_IN_FLIGHT=64
export ROLLOUT_MAX_QUEUED_JOBS=256
export ROLLOUT_TASKS_PER_JOB=2
export ROLLOUT_POLL_INTERVAL_S=15
export ROLLOUT_COALESCE_WINDOW_S=0.5
export ROLLOUT_RESULT_TTL_S=3600
export ROLLOUT_JOB_DIR_TTL_S=7200

# Relax-side rollout client values. Keep the token file readable only by the
# coordinator/trainer user, and never expose it to coding-agent Slurm workers.
export ROLLOUT_COORDINATOR_PUBLIC_URL=http://127.0.0.1:8910
export ROLLOUT_SGLANG_PUBLIC_URL=http://127.0.0.1:8080/v1
export ROLLOUT_SGLANG_MODEL=shuaishuaicdp/Code-X-SFT-27B
